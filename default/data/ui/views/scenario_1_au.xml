        <title>TopoIogy</title>
        <search>
          <query>index=telemetry sourcetype=cnc_srte_path_json source="srte_path_vlan"
| table _time host sr_policy_results{}.hops{}
| rename sr_policy_results{}.hops{} as hops
| eval hops_string=mvjoin(hops, ",")
| sort 0 host, _time
| streamstats count as seq by host
| eventstats last(hops_string) as latest_hops by host
| eventstats dc(hops_string) as unique_routes by host
| eval route_changed=if(unique_routes&gt;1, "YES", "NO")
| where seq=1
| eval hops_org=hops
| eval hop_index=mvrange(0, mvcount(hops))
| eval hops_with_index=mvzip(hop_index, hops, ":::")
| mvexpand hops_with_index
| rex field=hops_with_index "^(?&lt;hop_index&gt;[^:]+):::(?&lt;router_name&gt;.+)$"
| table host router_name hop_index route_changed unique_routes
| lookup router_lat_lon.csv router_name
| eval description="Tx&lt;br&gt;Rx", tooltip="", pathColor=if(path="cnc_vlan1001","red","green")
| eval customIcon="router3.png", markerSize=70, pathWeight=3
| rename host as path
| eval pathColor=if(path="cnc_vlan1002" OR path="cnc_vlan1003","red","green")
| eval markerPriority=if(path="cnc_vlan1002" OR path="cnc_vlan1003",2,1)
| appendpipe 
    [| stats count by router_name customIcon latitude longitude markerSize router
    | eval markerPriority=3
    | eval tooltip=substr(router_name,1,2)
    | eval path=router_name

    | fields - count]</query>
          <earliest>$PERIOD.earliest$</earliest>
          <latest>$PERIOD.latest$</latest>
        </search>
