<form version="1.1" theme="dark">
  <label>#1 Backbone Network Status</label>
  <description>Workshop scenario: latency was detected on a specific VLAN over the WDM backbone. Investigate and identify the root cause.</description>
  <fieldset submitButton="false" autoRun="true">
    <input type="time" token="PERIOD">
      <label>Period</label>
      <default>
        <earliest>-60m@m</earliest>
        <latest>now</latest>
      </default>
    </input>
  </fieldset>
  <row>
    <panel depends="$alwaysHideCSS$">
      <title>Style Sheet</title>
      <html>
        <style>
        #Panel1{max-width:40% !important;}
        #Panel2{max-width:60% !important;}
        #Panel3{max-width:20% !important;}
        #Panel4{max-width:20% !important;}
        </style>
      </html>
    </panel>
  </row>
  <row>
    <panel id="Panel1">
      <title>WDM Network Topology in Central Victoria</title>
      <viz type="leaflet_maps_app.maps-plus">
        <search>
          <query>index=telemetry sourcetype=cnc_srte_path_json 
| table _time host sr_policy_results{}.hops{} 
| rename sr_policy_results{}.hops{} as hops 
| eval hops_string = mvjoin(hops, ",") 
| sort 0 host, _time 
| streamstats count as seq by host 
| eventstats last(hops_string) as latest_hops by host 
| eventstats dc(hops_string) as unique_routes by host 
| eval route_changed=if(unique_routes&gt;1, "YES", "NO") 
| where seq=1 
| eval hops_org = hops 
| eval hop_index = mvrange(0, mvcount(hops)) 
| eval hops_with_index = mvzip(hop_index, hops, ":::") 
| mvexpand hops_with_index 
| rex field=hops_with_index "^(?&lt;hop_index&gt;[^:]+):::(?&lt;router_name&gt;.+)$" 
| table host router_name hop_index route_changed unique_routes 
| lookup au_router_areas.csv router_name 
| eval customIcon = "router.png", markerSize = 70, pathWeight = 3 
| rename host as path 
| rex field=path "cnc_vlan(?&lt;slice&gt;\d+)" 
| join type=left slice 
    [ search index=telemetry sourcetype=cnc_service_health_json 
    | spath subservice_health{} 
    | mvexpand subservice_health{} 
    | spath input=subservice_health{} 
    | search category=sr_policy 
    | stats last(health_score) as health_score last(health_status) as health_status by vpn_name device 
    | eval status=replace(health_status, "SERVICE_","") 
    | rex field=vpn_name "^NSS-5G_Slice_Vlan(?&lt;slice&gt;\d+)" 
    | fields slice health_score ] 
| eval pathColor = if(health_score&lt;=50, "red", "green") 
| eval markerPriority = if(health_score&lt;=50, 2, 1) 
| appendpipe 
    [ stats count by router_name customIcon latitude longitude markerSize router area 
    | eval markerPriority=3 
    | eval tooltip=router.": ".area 
    | eval path=router_name 
    | fields - count ]</query>
          <earliest>$PERIOD.earliest$</earliest>
          <latest>$PERIOD.latest$</latest>
          <refresh>1m</refresh>
          <refreshType>delay</refreshType>
        </search>
