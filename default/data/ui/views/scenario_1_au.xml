    <panel id="Panel2">
      <table>
        <title>VPN/Metrics</title>
        <search>
          <query>index=twamp sourcetype=twamp_csv
| rename "Source Ip" as src_ip, "Destination Ip" as dest_ip, "Session Name" as session_name
| rex field=session_name "^(?&lt;src_host&gt;[^-]+)-(?&lt;dest_host&gt;[^_]+)"
| bin span=1h _time
| stats avg(rt_dp95) as delay avg(rt_jp95) as jitter p95(dl_lostperc) as dl_lostperc p95(ul_lostperc) as ul_lostperc by _time src_host src_ip Interface dest_host dest_ip session_name
| eval dl_lostperc=ifnull(dl_lostperc,1000000)
| eval ul_lostperc=ifnull(ul_lostperc,1000000)
| stats avg(delay) as delay avg(jitter) as jitter p95(dl_lostperc) as dl_lostperc p95(ul_lostperc) as ul_lostperc by src_host src_ip Interface dest_host dest_ip session_name
| eval delay=round(delay,1), jitter=round(jitter,1), dl_lostperc=round(dl_lostperc/10000,1), ul_lostperc=round(ul_lostperc/10000,1)
| table session_name delay jitter dl_lostperc ul_lostperc
| eval slice=substr(session_name, 18, 4)
| join type=left slice [
| search index=telemetry sourcetype=cnc_srte_path_json source="srte_path_vlan"
| table _time host sr_policy_results{}.hops{}
| rename sr_policy_results{}.hops{} as hops
| eval src=mvindex(hops, 0), hop1=mvindex(hops, 1), hop2=mvindex(hops, 2), hop3=mvindex(hops, 3), dest=mvindex(hops, 4)
| stats count by _time host src hop1 hop2 hop3 dest
| eval slice=substr(host, 9, 4)]
| table session_name dl_lostperc ul_lostperc delay jitter src hop* dest
| search session_name=R2*
| sort session_name
| rename session_name as "Session name", ul_lostperc as "Packet Loss R2-&gt;R9[%]", dl_lostperc as "Packet Loss R9-&gt;R2[%]", delay as "Delay[ms]", jitter as "Jitter[us]", src as Src, hop* as Hop*, dest as Dest
| table "Session name" "Packet Loss R2-&gt;R9[%]" "Packet Loss R9-&gt;R2[%]" "Delay[ms]" "Jitter[us]" Src Hop* Dest</query>
          <earliest>$PERIOD.earliest$</earliest>
          <latest>$PERIOD.latest$</latest>
          <sampleRatio>1</sampleRatio>
        </search>
        <option name="count">20</option>
        <option name="dataOverlayMode">none</option>
        <option name="drilldown">none</option>
        <option name="percentagesRow">false</option>
        <option name="refresh.display">progressbar</option>
        <option name="rowNumbers">false</option>
        <option name="totalsRow">false</option>
        <option name="wrap">true</option>
        <format type="color" field="Packet Loss R2-&gt;R9[%]">
          <colorPalette type="list">[#252A2F,#CBA700,#D94E17]</colorPalette>
          <scale type="threshold">1,30</scale>
        </format>
      </table>
