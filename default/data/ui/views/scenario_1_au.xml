    <panel>
      <title>Network Slice Health Score</title>
      <table>
        <search>
          <query>index=telemetry sourcetype=cnc_service_health_json
| spath subservice_health{}
| mvexpand subservice_health{}
| spath input=subservice_health{}
| stats last(health_score) as health_score last(health_status) as health_status by vpn_name category device
| eval Status=replace(health_status, "SERVICE_","")
| rename health_score as Score, category as Category, vpn_name as Slice, device as Device
| fields Slice Device Category Status Score
| sort Score</query>
          <earliest>$PERIOD.earliest$</earliest>
          <latest>$PERIOD.latest$</latest>
          <refresh>1m</refresh>
          <refreshType>delay</refreshType>
        </search>
        <option name="count">18</option>
        <option name="drilldown">none</option>
        <option name="refresh.display">progressbar</option>
        <format type="color" field="Score">
          <colorPalette type="list">[#D41F1F,#CBA700,#55C169]</colorPalette>
          <scale type="threshold">30,51</scale>
        </format>
        <format type="color" field="Status">
          <colorPalette type="map">{"UP":#55C169,"DEGRADED":#CBA700}</colorPalette>
        </format>
      </table>
    </panel>
