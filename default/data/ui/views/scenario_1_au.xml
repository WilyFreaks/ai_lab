<form version="1.1" theme="dark">
  <label>[Cisco Showcase] Backbone Network Monitoring Dashboard</label>
  <description>Workshop scenario: latency was detected on a specific VLAN over the WDM backbone. Investigate and identify the root cause.</description>
  <fieldset submitButton="false" autoRun="true">
    <input type="time" token="PERIOD">
      <label>Period</label>
      <default>
        <earliest>-60m@m</earliest>
        <latest>now</latest>
      </default>
    </input>
  </fieldset>
  <row>
    <panel depends="$alwaysHideCSS$">
      <title>Single value</title>
      <html>
        <style>
        #Panel1{max-width:40% !important;}
        #Panel2{max-width:60% !important;}
        #Panel3{max-width:20% !important;}
        #Panel4{max-width:20% !important;}
        </style>
      </html>
    </panel>
  </row>
