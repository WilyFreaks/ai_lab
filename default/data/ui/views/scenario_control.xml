<form version="1.1" theme="light">
  <label>Scenario Control</label>
  <description>Changing the scenario reloads the saved activation, fault start, and fault duration from local/ai_lab_scenarios.conf (read-only status). Submit applies your edits: Enable sets &lt;scenario&gt;_activated to the current epoch time; Disable sets it to 0.</description>
  <init>
    <unset token="region_show_au"></unset>
    <unset token="region_show_jp"></unset>
  </init>
  <search id="region_status_bootstrap">
    <query>| workshopregion action="status" | eval region_lower=lower(region) | table region_lower</query>
    <done>
      <condition match="$result.region_lower$ != &quot;&quot;">
        <set token="region">$result.region_lower$</set>
        <set token="form.region">$result.region_lower$</set>
      </condition>
      <condition>
        <unset token="region"></unset>
        <unset token="form.region"></unset>
      </condition>
    </done>
  </search>
  <fieldset submitButton="true" autoRun="true">
    <input type="dropdown" token="scenario" searchWhenChanged="true" depends="$region$">
      <label>Scenario</label>
      <choice value="scenario_1">scenario_1</choice>
    </input>
    <input type="dropdown" token="active" depends="$scenario$">
      <label>Activation</label>
      <choice value="1">Enable (set epoch)</choice>
      <choice value="0">Disable (set 0)</choice>
    </input>
    <input type="text" token="fault_start" depends="$scenario$">
      <label>Fault Start (minutes)</label>
      <default>0</default>
    </input>
    <input type="text" token="fault_duration" depends="$scenario$">
      <label>Fault Duration (minutes)</label>
      <default>0</default>
    </input>
  </fieldset>
  <row>
    <panel>
      <html>
        <p style="margin:0 0 0.5em 0">
          <strong>Fault Start</strong> (minutes): Minutes after scenario activation (the saved &lt;scenario&gt;_activated epoch) before the simulated fault begins. Stored as &lt;scenario&gt;_fault_start in local/ai_lab_scenarios.conf. Use 0 to start the fault window at activation time.</p>
        <p style="margin:0">
          <strong>Fault Duration</strong> (minutes): How long the fault window stays active after it starts. Stored as &lt;scenario&gt;_fault_duration. Use 0 to keep the fault in effect until the scenario is deactivated (lab default behavior).</p>
      </html>
    </panel>
  </row>
  <row depends="$scenario$">
    <panel>
      <html>
        <img src="/static/app/ai_lab/$scenario$_topology_$region$.jpg" style="max-width:100%;height:auto;"/>
      </html>
    </panel>
    <panel>
      <html>
        <img src="/static/app/ai_lab/$scenario$_overview_$region$.jpg" style="max-width:100%;height:auto;"/>
      </html>
    </panel>
  </row>
  <row depends="$scenario$">
    <panel>
      <title>Current Status</title>
      <table>
        <search>
          <query>| scenariostatus scenario="$scenario$"
| rename status as Status, activation_local_time as "Activation Time"
| table scenario Status "Activation Time"</query>
          <refresh>30</refresh>
          <refreshType>delay</refreshType>
        </search>
        <option name="count">1</option>
        <option name="refresh.display">progressbar</option>
      </table>
    </panel>
  </row>
  <row depends="$active$">
    <panel>
      <table>
        <search>
          <query>| scenariocontrol action=set scenario="$scenario$" active="$active$" fault_start="$fault_start$" fault_duration="$fault_duration$"
| eval activated_local_time = strftime(activated, "%F %T %Z")
| fields status message scenario active activated_local_time fault_start fault_duration</query>
          <earliest>$earliest$</earliest>
          <latest>$latest$</latest>
        </search>
        <option name="count">10</option>
        <option name="refresh.display">progressbar</option>
      </table>
    </panel>
  </row>
  <row depends="$region$">
    <panel>
      <title>Workshop Dashboards</title>
      <html>
        <a href="/app/ai_lab/scenario_1_$region$" style="font-size: 20px;" target="_blank">#1 Backbone Network Status</a>
      </html>
    </panel>
  </row>
  <row depends="$region$">
    <panel>
      <title>Agent Rules &amp; Skills (plain text)</title>
      <html>
        <p style="margin:0 0 0.75em 0;color:#555;font-size:12px">Links open UTF-8 plain text (.txt mirrors of the Markdown) so attendees can select-all and paste into Cursor. Use &quot;Save As&quot; from the browser if you prefer a file.</p>
        <ul>
        <li>
            <a href="/static/app/ai_lab/agent_mcp_json.txt" target="_blank">MCP Config (JSON)</a>
          </li>
        <li>
            <a href="/static/app/ai_lab/agent_rules_en.txt" target="_blank">Agent Rules (English)</a>
          </li>
        <li>
            <a href="/static/app/ai_lab/agent_skills_en.txt" target="_blank">Agent Skills (English)</a>
          </li>
        <li>
            <a href="/static/app/ai_lab/agent_rules_jp.txt" target="_blank">Agent Rules (Japanese)</a>
          </li>
        <li>
            <a href="/static/app/ai_lab/agent_skills_jp.txt" target="_blank">Agent Skills (Japanese)</a>
          </li>
        </ul>
      </html>
    </panel>
  </row>
</form>