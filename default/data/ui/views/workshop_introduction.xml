<form version="1.1" script="workshop_introduction_submit_toggle.js" theme="light">
  <label>Workshop Introduction</label>
  <description>Set your time zone and select a region. The baseline data will be backfilled when you click the Submit button.</description>
  <!-- Initial state: JS runs | workshopregion action="status" once and sets tokens (no baseline &lt;search&gt;). -->
  <init>
    <unset token="region_locked"></unset>
    <unset token="region_unlocked"></unset>
  </init>
  <fieldset submitButton="true" autoRun="false">
    <input type="dropdown" token="region" depends="$region_unlocked$">
      <label>Region</label>
      <choice value="au">au</choice>
      <choice value="jp">jp</choice>
    </input>
  </fieldset>
  <row>
    <panel>
      <html>
        <div style="padding: 4px 0;">
          <img src="/static/app/ai_lab/data_sources.jpg" alt="Workshop data sources" style="max-width:100%; height:auto; border:1px solid #d9d9d9;"/>
        </div>
      </html>
    </panel>
  </row>
  <row depends="$region_locked$">
    <panel>
      <title>Save Region &amp; Start Result</title>
      <table>
        <search>
          <done>
            <condition match="true()">
              <set token="region_token">$result.region$</set>
              <set token="region">$result.region$</set>
              <set token="form.region">$result.region$</set>
              <set token="status_region">$result.region$</set>
              <set token="status_region_ready">$result.region_ready$</set>
              <set token="status_enabled">$result.baseline_generation_enabled$</set>
              <set token="status_backfill_start">$result.backfill_start_time$</set>
              <set token="status_backfill_completed">$result.backfill_completed$</set>
              <set token="status_backfill_duration">$result.backfill_duration$</set>
              <set token="status_backfill_completed_time">$result.backfill_completed_time$</set>
              <set token="status_backfill_run_started_time">$result.backfill_run_started_time$</set>
              <set token="region_locked">true</set>
              <unset token="region_unlocked"></unset>
            </condition>
          </done>
          <query>| workshopregion action="set" region="$status_region$"
| fields status action region launcher_message initial_backfill backfill_start_time_local backfill_head_time_local backfill_run_started_time_local backfill_completed backfill_completed_time_local backfill_duration</query>
          <earliest>$earliest$</earliest>
          <latest>$latest$</latest>
        </search>
        <option name="count">1</option>
        <option name="drilldown">none</option>
        <option name="refresh.display">progressbar</option>
      </table>
    </panel>
  </row>
</form>